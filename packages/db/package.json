{
  "name": "@tact/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@neondatabase/serverless": "1.1.0",
    "@tact/game-engine": "workspace:*",
    "drizzle-orm": "0.45.2"
  },
  "devDependencies": {
    "@types/node": "24.13.2",
    "drizzle-kit": "0.31.10",
    "typescript": "5.9.3"
  }
}
