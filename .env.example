# Neon pooled connection for the application runtime.
DATABASE_URL=postgresql://user:password@example-pooler.neon.tech/tact?sslmode=require

# Neon direct connection for Drizzle migrations.
DATABASE_URL_UNPOOLED=postgresql://user:password@example.neon.tech/tact?sslmode=require

# Signed guest sessions and Neon Auth cookie encryption. Generate each with:
# openssl rand -base64 32
TACT_SESSION_SECRET=replace-with-at-least-32-bytes
NEON_AUTH_COOKIE_SECRET=replace-with-at-least-32-bytes

# Populated by a Neon Auth-enabled Vercel integration when account login is enabled.
# NEON_AUTH_BASE_URL=https://your-project.neonauth.example

# MPP challenges are HMAC-bound with this secret. Generate with:
# openssl rand -base64 32
MPP_SECRET_KEY=replace-with-at-least-32-bytes
MPP_REALM=http://localhost:3000
MPP_RECIPIENT=0x0000000000000000000000000000000000000000
MPP_NETWORK=testnet
# Optional TIP-20 token override. Defaults to testnet pathUSD or mainnet USDC.
# MPP_CURRENCY=0x20c0000000000000000000000000000000000000

# Decimal stablecoin amount charged by the integration-test endpoint.
MPP_DEMO_PRICE=0.001
