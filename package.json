{
  "name": "tact",
  "version": "3.0.0-alpha.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo dev --filter=@tact/web",
    "build": "turbo build --filter=@tact/web",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "db:generate": "pnpm --filter @tact/db db:generate",
    "db:migrate": "pnpm --filter @tact/db db:migrate"
  },
  "devDependencies": {
    "turbo": "2.10.2",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "packageManager": "pnpm@11.9.0"
}
